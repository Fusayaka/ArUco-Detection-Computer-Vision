# ==========================================
# 1. DATASETS & MODEL WEIGHTS
# ==========================================
# Ignore raw and processed data to save repository space
data/raw/
data/processed/

# Ignore PyTorch/YOLO model weights
*.pt

# ==========================================
# 2. LOGS & OUTPUTS
# ==========================================
# Ignore training runs generated by Ultralytics YOLO
runs/

# Ignore all generated outputs (submission.csv, visualizations, etc.)
output/*

!*/.gitkeep

# ==========================================
# 3. PYTHON CACHE & ENVIRONMENTS
# ==========================================
__pycache__/
*.py[cod]
*$py.class

.env

# Ignore virtual environment folders
venv/